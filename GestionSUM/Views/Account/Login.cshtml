@model GestionSUM.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-5">
        <div class="card glass-card border-0 shadow-lg animate-fade-in rounded-4">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="bi bi-shield-lock-fill display-3 text-primary mb-3"></i>
                    <h2 class="fw-bold text-dark">Bienvenido</h2>
                    <p class="text-muted">Ingresá tus credenciales para gestionar el SUM</p>
                </div>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="form-floating mb-3">
                        <input name="email" type="email" class="form-control border-0 shadow-sm rounded-3" id="emailInput" placeholder="nombre@ejemplo.com" required>
                        <label for="emailInput" class="text-muted">Correo electrónico</label>
                    </div>

                    <div class="form-floating mb-4">
                        <input name="password" type="password" class="form-control border-0 shadow-sm rounded-3" id="passwordInput" placeholder="Contraseña" required>
                        <label for="passwordInput" class="text-muted">Contraseña</label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill shadow-sm hover-lift fw-bold">
                        <i class="bi bi-box-arrow-in-right me-2"></i> Iniciar Sesión
                    </button>
                </form>

                <div class="text-center mt-4">
                    <p class="small text-muted mb-0">
                        ¿No tenés cuenta?
                        <a asp-action="Register" class="text-primary fw-bold text-decoration-none">Registrate</a>
                    </p>
                </div>
            </div>
        </div>
        
@*         <div class="text-center mt-4 animate-fade-in delay-1">
            <a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none small">
                <i class="bi bi-arrow-left me-1"></i> Volver al inicio
            </a>
        </div> *@
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}