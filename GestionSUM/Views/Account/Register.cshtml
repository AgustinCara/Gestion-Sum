@{
    ViewData["Title"] = "Registro de Usuario";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 90vh; margin-top: 20px;">
    <div class="col-md-6">
        <div class="card glass-card border-0 shadow-lg animate-fade-in rounded-4">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="bi bi-person-plus-fill display-3 text-primary mb-3"></i>
                    <h2 class="fw-bold text-dark">Nuevo Usuario</h2>
                    <p class="text-muted">Completá los datos para acceder al sistema del SUM</p>
                </div>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <input name="nombre" type="text" class="form-control border-0 shadow-sm rounded-3" placeholder="Nombre completo" required>
                                <label class="text-muted">Nombre Completo</label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <input name="depto" type="text" class="form-control border-0 shadow-sm rounded-3" placeholder="Depto" required>
                                <label class="text-muted">Departamento</label>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-3">
                        <input name="email" type="email" class="form-control border-0 shadow-sm rounded-3" placeholder="Email" required>
                        <label class="text-muted">Correo electrónico</label>
                    </div>

                    <div class="form-floating mb-4">
                        <input name="password" type="password" class="form-control border-0 shadow-sm rounded-3" placeholder="Password" required>
                        <label class="text-muted">Contraseña</label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill shadow-sm hover-lift fw-bold">
                        <i class="bi bi-check-circle me-2"></i> Crear Cuenta
                    </button>
                </form>

                <div class="text-center mt-4">
                    <p class="small text-muted mb-0">
                        ¿Ya tenés cuenta?
                        <a asp-action="Login" class="text-primary fw-bold text-decoration-none">Iniciá sesión acá</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>