@model GestionSUM.Models.SumInfo
@using GestionSUM.Services
@using GestionSUM.Models

@{
    ViewData["Title"] = "Sobre el SUM";
}

<div class="container-fluid px-4 px-md-5 mt-5">

    <div class="card glass-card border-0 shadow-lg mb-4 animate-fade-in">
        <div class="card-body text-center py-4">
            <h1 class="display-5 fw-bold text-dark mb-1">Información del SUM</h1>
            <div class="h5 text-muted fw-light">Edificio Monte Grande</div>
        </div>
    </div>

    <div class="card glass-card border-0 shadow-sm mb-4 animate-fade-in delay-1">
        <div class="card-body d-flex justify-content-between align-items-center py-2">
            <div>
                @if (UsuarioActual.Rol == RolUsuario.Administrador)
                {
                    <a asp-controller="AdminSum" asp-action="Edit" class="btn btn-dark rounded-pill px-4 shadow-sm hover-lift">
                        <i class="bi bi-pencil-square me-2"></i> Editar Info
                    </a>
                }
            </div>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark rounded-pill px-4 shadow-sm hover-lift">
                <i class="bi bi-arrow-left me-2"></i> Volver
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-7 animate-fade-in delay-2">
            <div class="card glass-card border-0 shadow-sm mb-4 rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white border-0 py-3">
                    <h5 class="mb-0"><i class="bi bi-building me-2"></i> Información General</h5>
                </div>
                <div class="card-body">
                    <p class="lead text-muted">@Model.InformacionGeneral</p>
                    <hr class="opacity-10">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="p-3 border rounded-3 bg-white bg-opacity-50">
                                <small class="text-uppercase fw-bold text-primary d-block mb-1">Capacidad</small>
                                <span class="h5">@Model.Capacidad</span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 border rounded-3 bg-white bg-opacity-50">
                                <small class="text-uppercase fw-bold text-primary d-block mb-1">Días</small>
                                <span class="h5">Lunes a Domingo</span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 border rounded-3 bg-white bg-opacity-50">
                                <small class="text-uppercase fw-bold text-success d-block mb-1">Turnos</small>
                                <ul class="list-unstyled mb-0">
                                    <li><strong>Día:</strong> 10:00 a 18:00 hs</li>
                                    <li><strong>Noche:</strong> 19:00 a 02:00 hs</li>
                                </ul>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 border rounded-3 bg-white bg-opacity-50">
                                <small class="text-uppercase fw-bold text-danger d-block mb-1">Políticas</small>
                                <ul class="list-unstyled mb-0">
                                    <li><strong>Reserva:</strong> 6h anticipación</li>
                                    <li><strong>Cancelación:</strong> 2h anticipación</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card glass-card border-0 shadow-sm mb-4 rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white border-0 py-3">
                    <h5 class="mb-0"><i class="bi bi-journal-text me-2"></i> Reglamento de Uso</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush bg-transparent">
                        @foreach (var regla in Model.Reglas.Split('\n'))
                        {
                            @if (!string.IsNullOrWhiteSpace(regla))
                            {
                                <li class="list-group-item bg-transparent border-0 d-flex align-items-start px-0">
                                    <i class="bi bi-check2-circle text-primary me-3 mt-1"></i>
                                    <span>@regla.Trim()</span>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-5 animate-fade-in delay-3">
            <div class="card glass-card border-0 shadow-sm mb-4 rounded-4 overflow-hidden animate-fade-in delay-3">
                <div class="card-header bg-dark text-white border-0 py-2">
                    <h6 class="mb-0 py-1"><i class="bi bi-box-seam me-2"></i> Equipamiento Incluido</h6>
                </div>
                <div class="card-body py-3">
                    <div class="row g-2">
                        @foreach (var equip in Model.Equipamiento.Split('\n'))
                        {
                            @if (!string.IsNullOrWhiteSpace(equip))
                            {
                                <div class="col-6">
                                    <div class="d-flex align-items-center p-2 rounded-3 border bg-light bg-opacity-50 hover-lift-sm">
                                        <i class="bi bi-check-circle-fill text-primary me-2" style="font-size: 0.85rem;"></i>
                                        <span class="small fw-medium text-secondary">@equip.Trim()</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="card glass-card border-0 shadow-lg overflow-hidden mb-5 rounded-4 p-2">
                <div id="carouselSUMInfo" class="carousel slide carousel-fade" data-bs-ride="carousel">
                    <div class="carousel-inner rounded-3">
                        <div class="carousel-item active">
                            <img src="~/img/sum/sum1.jpg" class="d-block w-100 info-carousel-img" alt="SUM 1">
                        </div>
                        <div class="carousel-item">
                            <img src="~/img/sum/sum2.jpg" class="d-block w-100 info-carousel-img" alt="SUM 2">
                        </div>
                        <div class="carousel-item">
                            <img src="~/img/sum/sum3.jpg" class="d-block w-100 info-carousel-img" alt="SUM 3">
                        </div>
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#carouselSUMInfo" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon rounded-circle"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#carouselSUMInfo" data-bs-slide="next">
                        <span class="carousel-control-next-icon rounded-circle"></span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background: radial-gradient(circle at top right, #f8f9fa, #e2e8f0);
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        min-height: 100vh;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.6) !important;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.3) !important;
    }

    .info-carousel-img {
        height: 370px;
        object-fit: cover;
    }

    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .hover-lift:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    /* Animaciones */
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in {
        opacity: 0;
        animation: fadeIn 0.7s ease-out forwards;
    }

    .delay-1 {
        animation-delay: 0.1s;
    }

    .delay-2 {
        animation-delay: 0.2s;
    }

    .delay-3 {
        animation-delay: 0.3s;
    }

    /* Custom Scrollbar para las listas si son muy largas */
    .list-group {
        max-height: 400px;
        overflow-y: auto;
    }
</style>