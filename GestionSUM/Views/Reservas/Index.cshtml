@using GestionSUM.Services
@using GestionSUM.Models
@model IEnumerable<GestionSUM.Models.Reserva>

@{
    ViewData["Title"] = "Reservas SUM";
}

<div class="container-fluid px-4 px-md-5 mt-5">

    <div class="card glass-card border-0 shadow-lg mb-4 animate-fade-in">
        <div class="card-body text-center py-4">
            <h1 class="display-5 fw-bold text-dark mb-1">Listado de Reservas</h1>
            <p class="text-muted">Próximos eventos en el Edificio Monte Grande</p>
        </div>
    </div>

    <div class="card glass-card border-0 shadow-sm mb-4 animate-fade-in delay-1">
        <div class="card-body d-flex flex-wrap justify-content-center gap-3">
            <a asp-action="Create" asp-route-origen="reservas"
               class="btn btn-primary rounded-pill px-4 shadow-sm hover-lift">
                <i class="bi bi-calendar-plus me-2"></i> Nueva Reserva
            </a>

            @if (UsuarioActual.Rol == RolUsuario.Administrador)
            {
                <a asp-action="Historial" class="btn btn-dark rounded-pill px-4 shadow-sm hover-lift">
                    <i class="bi bi-x-circle me-2"></i> Historial Cancelaciones
                </a>
                <a asp-action="HistorialReservas" class="btn btn-dark rounded-pill px-4 shadow-sm hover-lift">
                    <i class="bi bi-archive me-2"></i> Historial Reservas
                </a>
            }
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-4 shadow-sm animate-fade-in">
            <i class="bi bi-exclamation-triangle me-2"></i> @TempData["Error"]
        </div>
    }

    <div class="card glass-card border-0 shadow-lg rounded-4 overflow-hidden animate-fade-in delay-2">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-dark text-white">
                    <tr>
                        <th class="ps-4 py-3">Fecha</th>
                        <th class="py-3">Turno y Horario</th>
                        <th class="py-3">Usuario</th>
                        <th class="py-3">Dpto</th>
                        @if (UsuarioActual.Rol == RolUsuario.Administrador)
                        {
                            <th class="text-center pe-4 py-3">Acciones</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold text-dark">@r.Fecha.ToString("dd/MM/yyyy")</span>
                            </td>
                            <td>
                                <div class="badge bg-info text-dark rounded-pill px-3">
                                    @r.Turno?.MomentoDelDia
                                </div>
                                <br />
                                <small class="text-muted ms-1">
                                    <i class="bi bi-clock me-1"></i> @r.Turno?.HoraInicio.ToString(@"hh\:mm") - @r.Turno?.HoraFin.ToString(@"hh\:mm")
                                </small>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <span>@r.Usuario?.Nombre</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border shadow-sm">
                                    <i class="bi bi-building me-1"></i> @r.Usuario?.Departamento
                                </span>
                            </td>
                            @if (UsuarioActual.Rol == RolUsuario.Administrador)
                            {
                                <td class="text-center pe-4">
                                    <a asp-action="Delete" asp-route-id="@r.Id"
                                       class="btn btn-outline-danger btn-sm rounded-pill px-3 hover-lift">
                                        <i class="bi bi-trash me-1"></i> Cancelar
                                    </a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-4 animate-fade-in delay-3">
        <a asp-controller="Home" asp-action="Index"
           class="btn btn-link text-decoration-none text-muted hover-lift">
            <i class="bi bi-arrow-left me-2"></i> Volver al Inicio
        </a>
    </div>

</div>

<style>
    /* Reutilizamos tus estilos de la Home para coherencia total */
    body {
        background: radial-gradient(circle at top right, #f8f9fa, #e2e8f0);
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        min-height: 100vh;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.6) !important;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.3) !important;
    }

    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .hover-lift:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    /* Estilos específicos para la tabla */
    .table thead th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    /* Animaciones */
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in {
        opacity: 0;
        animation: fadeIn 0.7s ease-out forwards;
    }

    .delay-1 {
        animation-delay: 0.1s;
    }

    .delay-2 {
        animation-delay: 0.2s;
    }

    .delay-3 {
        animation-delay: 0.3s;
    }
</style>